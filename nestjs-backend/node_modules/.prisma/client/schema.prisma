// Prisma Schema — Student Access Control System
// Run: npx prisma migrate dev --name init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum IdentityProvider {
  LOCAL
  THAID
}

enum AccessType {
  IN
  OUT
}

model Parent {
  id               String           @id @default(uuid())
  name             String
  phone            String           @unique
  email            String           @unique
  passwordHash     String?          @map("password_hash")
  // ThaID / OIDC fields — reserved for future integration
  thaidSub         String?          @unique @map("thaid_sub")
  identityProvider IdentityProvider @default(LOCAL) @map("identity_provider")
  isVerified       Boolean          @default(false) @map("is_verified")
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")

  mappings ParentStudentMapping[]
  devices  Device[]

  @@map("parents")
}

model Student {
  id                String   @id @default(uuid())
  // ID used by the external Access Control system
  externalStudentId String   @unique @map("external_student_id")
  studentCode       String   @unique @map("student_code")
  name              String
  createdAt         DateTime @default(now()) @map("created_at")

  mappings   ParentStudentMapping[]
  accessLogs AccessLog[]

  @@map("students")
}

model ParentStudentMapping {
  id        String @id @default(uuid())
  parentId  String @map("parent_id")
  studentId String @map("student_id")

  parent  Parent  @relation(fields: [parentId], references: [id], onDelete: Cascade)
  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([parentId, studentId])
  @@map("parent_student_mapping")
}

model AccessLog {
  id         String     @id @default(uuid())
  studentId  String     @map("student_id")
  accessTime DateTime   @map("access_time")
  type       AccessType
  gateName   String     @map("gate_name")
  createdAt  DateTime   @default(now()) @map("created_at")

  student Student @relation(fields: [studentId], references: [id])

  // Deduplication: prevent identical events being inserted twice
  @@unique([studentId, accessTime, type], name: "unique_access_event")
  @@index([studentId, accessTime(sort: Desc)])
  @@map("access_logs")
}

model Device {
  id        String   @id @default(uuid())
  parentId  String   @map("parent_id")
  fcmToken  String   @unique @map("fcm_token")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  parent Parent @relation(fields: [parentId], references: [id], onDelete: Cascade)

  @@map("devices")
}
