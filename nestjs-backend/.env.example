# Copy this file to .env and fill in the real values.
# .env is gitignored — never commit real secrets.
#   cp .env.example .env

# ─── Database ───────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@localhost:5432/student?schema=public"

# ─── JWT ────────────────────────────────────────────────────
JWT_SECRET="change-me-to-a-long-random-string"
JWT_EXPIRES_IN="7d"

# ─── Internal API (must match fastapi-integration) ──────────
INTERNAL_API_KEY="change-me-internal-secret-key"

# ─── Firebase Admin SDK ─────────────────────────────────────
# Get firebase-service-account.json from the team (also gitignored)
FIREBASE_SERVICE_ACCOUNT_PATH="./firebase-service-account.json"

# ─── App ────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
APP_ENV=local

# ─── Security / runtime ─────────────────────────────────────
# CORS allowlist: comma-separated origins. Leave empty in dev (reflects origin);
# in production an empty value blocks all cross-origin requests (fail closed).
CORS_ORIGIN=
# Global rate limit (per client IP): RATE_LIMIT_MAX requests per RATE_LIMIT_TTL_MS.
# Internal machine-to-machine endpoints (/internal/*) are exempt.
RATE_LIMIT_TTL_MS=60000
RATE_LIMIT_MAX=30

# ─── Business rules ─────────────────────────────────────────
# Curfew window in Thai local time (HH:MM). An IN scan inside the window is
# flagged "late". The window crosses midnight (start in the evening, end in the
# morning). Defaults to 22:30–06:00 if unset.
CURFEW_START=22:30
CURFEW_END=06:00

# ─── ThaID (sandbox) ────────────────────────────────────────
# Credentials come from the registered RP (key_sandbox.pdf) — ask the supervisor.
# redirect_uri MUST match the registered callback exactly.
THAID_BASE_URL="https://imauthsbx.bora.dopa.go.th"
THAID_CLIENT_ID="<your-thaid-client-id>"
THAID_CLIENT_SECRET="<your-thaid-client-secret>"
THAID_REDIRECT_URI="https://mfuengage.mfu.ac.th"
THAID_SCOPE="pid name openid"
THAID_API_KEY="<your-thaid-api-key>"
