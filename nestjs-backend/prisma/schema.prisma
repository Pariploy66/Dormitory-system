generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Parent {
  id               String                 @id @default(uuid())
  citizenId        String                 @unique @map("citizen_id")
  thaidSub         String?                @unique @map("thaid_sub")
  name             String
  identityProvider IdentityProvider       @default(THAID) @map("identity_provider")
  isVerified       Boolean                @default(false) @map("is_verified")
  createdAt        DateTime               @default(now()) @map("created_at")
  updatedAt        DateTime               @updatedAt @map("updated_at")
  devices          Device[]
  mappings         ParentStudentMapping[]
  authLogs         AuthLog[]

  @@map("parents")
}

model Student {
  id                String                 @id @default(uuid())
  externalStudentId String                 @unique @map("external_student_id")
  studentCode       String                 @unique @map("student_code")
  name              String
  createdAt         DateTime               @default(now()) @map("created_at")
  dormitory         String?
  roomNumber        String?                @map("room_number")
  accessLogs        AccessLog[]
  mappings          ParentStudentMapping[]

  @@map("students")
}

model ParentStudentMapping {
  id        String  @id @default(uuid())
  parentId  String  @map("parent_id")
  studentId String  @map("student_id")
  parent    Parent  @relation(fields: [parentId], references: [id], onDelete: Cascade)
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([parentId, studentId])
  @@map("parent_student_mapping")
}

model AccessLog {
  id         String     @id @default(uuid())
  studentId  String     @map("student_id")
  accessTime DateTime   @map("access_time")
  type       AccessType
  gateName   String     @map("gate_name")
  createdAt  DateTime   @default(now()) @map("created_at")
  student    Student    @relation(fields: [studentId], references: [id])

  @@unique([studentId, accessTime, type], name: "unique_access_event")
  @@index([studentId, accessTime(sort: Desc)])
  @@map("access_logs")
}

model Device {
  id        String   @id @default(uuid())
  parentId  String   @map("parent_id")
  fcmToken  String   @unique @map("fcm_token")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  parent    Parent   @relation(fields: [parentId], references: [id], onDelete: Cascade)

  @@map("devices")
}

model AuthLog {
  id        String    @id @default(uuid())
  parentId  String    @map("parent_id")
  event     AuthEvent
  ipAddress String?   @map("ip_address")
  userAgent String?   @map("user_agent")
  createdAt DateTime  @default(now()) @map("created_at")
  parent    Parent    @relation(fields: [parentId], references: [id], onDelete: Cascade)

  @@index([parentId, createdAt(sort: Desc)])
  @@map("auth_logs")
}

enum IdentityProvider {
  LOCAL
  THAID
}

enum AuthEvent {
  LOGIN
  LOGOUT
}

enum AccessType {
  IN
  OUT
}
