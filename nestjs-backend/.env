# ─── Database ───────────────────────────────────────────────
# รูปแบบ: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://postgres:171247@localhost:5432/student?schema=public"

# ─── JWT ────────────────────────────────────────────────────
JWT_SECRET="change-me-to-a-long-random-string"
JWT_EXPIRES_IN="7d"

# ─── Internal API (shared with FastAPI) ─────────────────────
INTERNAL_API_KEY="change-me-internal-secret-key"

# ─── Firebase Admin SDK ─────────────────────────────────────
# Path to your serviceAccountKey.json downloaded from Firebase console
FIREBASE_SERVICE_ACCOUNT_PATH="./firebase-service-account.json"

# ─── App ────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
