# Copy this file to .env.local and fill in the real values.
# .env.local is gitignored — never commit real secrets.

APP_ENV=local
NESTJS_BASE_URL="http://localhost:3000"

# Must match nestjs-backend INTERNAL_API_KEY
INTERNAL_API_KEY="change-me-internal-secret-key"

# External access-control system (the dorm gate API)
EXTERNAL_API_BASE_URL="https://your-access-control-api"
EXTERNAL_API_KEY="<your-external-api-key>"

PORT=8000
