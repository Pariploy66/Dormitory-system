# ───────────────────────────────────────────────────────────────
# Env files
# NOTE: .env is intentionally tracked for this team project so everyone
# shares the same dev config. Do NOT put production secrets here.
# (Local-only overrides go in .env.local, which stays ignored.)
# ───────────────────────────────────────────────────────────────
.env.local
.env.*.local

# ───────────────────────────────────────────────────────────────
# Node / NestJS (nestjs-backend)
# ───────────────────────────────────────────────────────────────
node_modules/
dist/
build/
*.tsbuildinfo
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm/
coverage/

# ───────────────────────────────────────────────────────────────
# Python / FastAPI (fastapi-integration)
# ───────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
env/
.pytest_cache/
.mypy_cache/

# ───────────────────────────────────────────────────────────────
# Flutter / Dart (flutter-app has its own .gitignore too)
# ───────────────────────────────────────────────────────────────
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
**/build/
*.iml

# ───────────────────────────────────────────────────────────────
# IDE / Editor / OS
# ───────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
.DS_Store
Thumbs.db
