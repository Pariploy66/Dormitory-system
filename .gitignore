# ───────────────────────────────────────────────────────────────
# Env files
# NOTE: This project is still mockup stage (pre-production), so each
# service only uses .env.local (gitignored, per-developer dev config).
# When this goes to production, reintroduce a tracked .env baseline
# plus .env.preprod / .env.prod tiers.
# ───────────────────────────────────────────────────────────────
.env
.env.local
.env.*.local
.env.preprod
.env.prod

# ───────────────────────────────────────────────────────────────
# Postman collection — local only, not shared via git
# ───────────────────────────────────────────────────────────────
postman/

# ───────────────────────────────────────────────────────────────
# Secrets — NEVER commit (Firebase Admin private key, service accounts)
# ───────────────────────────────────────────────────────────────
firebase-service-account.json
*-service-account.json
*serviceAccountKey*.json

# ───────────────────────────────────────────────────────────────
# Node / NestJS (nestjs-backend)
# ───────────────────────────────────────────────────────────────
node_modules/
dist/
build/
*.tsbuildinfo
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm/
coverage/

# ───────────────────────────────────────────────────────────────
# Python / FastAPI (fastapi-integration)
# ───────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
env/
.pytest_cache/
.mypy_cache/

# ───────────────────────────────────────────────────────────────
# Flutter / Dart (flutter-app has its own .gitignore too)
# ───────────────────────────────────────────────────────────────
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
**/build/
*.iml

# ───────────────────────────────────────────────────────────────
# IDE / Editor / OS
# ───────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
.DS_Store
Thumbs.db
