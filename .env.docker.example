# ─────────────────────────────────────────────────────────────────────────────
# Docker Compose environment — copy to .env.docker and fill in real values.
# .env.docker is git-ignored (never commit real secrets).
#
#   cp .env.docker.example .env.docker
#   docker compose up --build
# ─────────────────────────────────────────────────────────────────────────────

# ── Postgres (compose builds DATABASE_URL from these) ────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=student

# ── NestJS ───────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d
# Must be identical in NestJS and FastAPI
INTERNAL_API_KEY=change-me-internal-secret-key
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# ── ThaID (government sandbox) — ask the team for real values ─────────────────
THAID_BASE_URL=https://imauthsbx.bora.dopa.go.th
THAID_CLIENT_ID=
THAID_CLIENT_SECRET=
THAID_REDIRECT_URI=
THAID_SCOPE=pid name openid
THAID_API_KEY=

# ── FastAPI (external Access Control API) ────────────────────────────────────
EXTERNAL_API_BASE_URL=https://access-control.example.com/api
EXTERNAL_API_KEY=
POLL_INTERVAL_SECONDS=30
